NODE_ENV=development
PORT=3000

# MongoDB Configuration
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=driver
MONGO_INITDB_DATABASE=hypertube

# MongoDB Connection URI
MONGODB_URI=mongodb://admin:driver@mongo:27017/hypertube?authSource=admin

# Mongo Express Configuration
ME_CONFIG_MONGODB_ADMINUSERNAME=admin
ME_CONFIG_MONGODB_ADMINPASSWORD=driver
ME_CONFIG_MONGODB_URL=mongodb://admin:driver@mongo:27017/
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=admin123

# Logging
ENABLE_REQUEST_LOGGING=true
