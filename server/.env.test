# Test Environment Variables
# This file contains non-sensitive test configuration
# It is loaded by tests/setup-env.ts before running Jest tests

NODE_ENV=test
PORT=3000
MONGODB_URI=mongodb://localhost:27017/hypertube_test
ENABLE_REQUEST_LOGGING=false
JWT_ACCESS_SECRET=test-access-secret-key-change-in-production
JWT_REFRESH_SECRET=test-refresh-secret-key-change-in-production
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d
